{
  "name": "alg0.dev",
  "type": "module",
  "version": "0.0.2",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/generate-og.mjs && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "husky",
    "og:generate": "node scripts/generate-og.mjs",
    "fonts:subset": "node scripts/subset-fonts.mjs",
    "format": "prettier . --write",
    "lint": "eslint . --fix"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "@tailwindcss/vite": "4.3.3",
    "astro": "7.1.1",
    "tailwindcss": "4.3.3"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "5.10.0",
    "eslint": "10.7.0",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-promise": "7.3.0",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "prettier": "3.9.5",
    "shiki": "4.3.1",
    "subset-font": "^2.5.0"
  }
}
