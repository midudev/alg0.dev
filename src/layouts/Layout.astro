---
import "@styles/global.css"
import type { Locale } from "@i18n/translations"
import { translations } from "@i18n/translations"

interface Props {
  locale?: Locale
  title?: string
  description?: string
  ogImage?: string
  canonicalURL?: string
  robots?: string
  structuredData?: Record<string, unknown>
}

const locale = (Astro.props.locale ?? "en") as Locale
const t = translations[locale]
const ogLocale = locale === "es" ? "es_ES" : "en_US"

const {
  title = t.siteTitle,
  description = t.siteDescription,
  ogImage = "/og-image.png",
  canonicalURL = new URL(normalizePath(Astro.url.pathname), Astro.site).href,
  robots = "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1",
  structuredData,
} = Astro.props

const siteName = "alg0.dev"
const twitterAuthor = "@midudev"

function normalizePath(path: string) {
  if (path === "/") return path
  return `${path.replace(/\/+$/, "")}/`
}

const pathname = normalizePath(Astro.url.pathname)
const basePath = locale === "es" && pathname.startsWith("/es/")
  ? pathname.slice(3) || "/"
  : pathname
const enAlternateUrl = new URL(basePath, Astro.site).href
const esAlternateUrl = new URL(basePath === "/" ? "/es/" : `/es${basePath}`, Astro.site).href
const alternateOgLocale = locale === "es" ? "en_US" : "es_ES"
const defaultStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: siteName,
  description,
  url: canonicalURL,
  applicationCategory: "EducationalApplication",
  operatingSystem: "Any",
  inLanguage: locale,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  author: {
    "@type": "Person",
    name: "Miguel Ángel Durán",
    url: "https://midu.dev",
  },
}
---

<!doctype html>
<html lang={locale} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Fonts (Latin subsets) — both paint above the fold -->
    <link
      rel="preload"
      href="/fonts/GeistPixel-Square.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/GeistMono-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Primary Meta Tags -->
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#000000" />
    <script is:inline>
      const savedTheme = document.cookie
        .split('; ')
        .find((cookie) => cookie.startsWith('theme='))
        ?.split('=')[1]
      const theme =
        savedTheme === 'light' || savedTheme === 'dark'
          ? savedTheme
          : window.matchMedia('(prefers-color-scheme: light)').matches
            ? 'light'
            : 'dark'
      document.documentElement.dataset.theme = theme
      document.documentElement.style.colorScheme = theme
      document.querySelector('meta[name="theme-color"]')?.setAttribute(
        'content',
        theme === 'light' ? '#ffffff' : '#000000',
      )
    </script>
    <link rel="canonical" href={canonicalURL} />
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={alternateOgLocale} />
    <link rel="alternate" hreflang="en" href={enAlternateUrl} />
    <link rel="alternate" hreflang="es" href={esAlternateUrl} />
    <link rel="alternate" hreflang="x-default" href={enAlternateUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterAuthor} />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(structuredData ?? defaultStructuredData)}
    />
  </head>
  <body class="bg-black text-gray-100 font-sans antialiased">
    <!-- Skip to main content link for keyboard/screen reader users -->
    <a href="#main-content" class="skip-link">
      {locale === "es" ? "Ir al contenido principal" : "Skip to main content"}
    </a>
    <slot />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  html {
    background: var(--surface);
  }

  /* Skip link — visible only on focus */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 16px;
    z-index: 100;
    padding: 8px 16px;
    background: #fff;
    color: #000;
    border-radius: 0 0 8px 8px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: top 0.2s ease;
  }
  .skip-link:focus {
    top: 0;
    outline: 2px solid #888;
    outline-offset: 2px;
  }

  /* Visible focus rings for keyboard navigation */
  :focus-visible {
    outline: 2px solid #888;
    outline-offset: 2px;
  }

  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    background: var(--subtle-strong);
    border-radius: 3px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--subtle-hover);
  }

  /* Custom range slider for speed */
  input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
    cursor: pointer;
  }
  input[type="range"]::-webkit-slider-runnable-track {
    height: 4px;
    background: var(--subtle-strong);
    border-radius: 2px;
  }
  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 12px;
    height: 12px;
    background: var(--foreground);
    border-radius: 50%;
    margin-top: -4px;
    transition: transform 0.15s ease;
  }
  input[type="range"]::-webkit-slider-thumb:hover {
    transform: scale(1.15);
  }
  input[type="range"]::-moz-range-track {
    height: 4px;
    background: var(--subtle-strong);
    border-radius: 2px;
  }
  input[type="range"]::-moz-range-thumb {
    width: 12px;
    height: 12px;
    background: var(--foreground);
    border-radius: 50%;
    border: none;
  }

  /* Respect user preference for reduced motion */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }

  /* Screen-reader only utility */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
