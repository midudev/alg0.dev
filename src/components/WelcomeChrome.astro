---
/**
 * Static welcome copy + keyboard shortcuts (SSR).
 * Interactive showcase is driven by `showcase.ts` (plain JS).
 */
import type { Locale } from "@i18n/translations"
import { translations } from "@i18n/translations"

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = translations[locale]
// Description may include a newline for source readability — flatten for display.
const description = t.welcomeDescription.replace(/\n+/g, " ").trim()
---

<div class="text-center max-w-xl shrink-0 px-4 md:px-0" data-welcome-chrome>
  <h1
    class="text-lg md:text-xl font-semibold text-white mb-2 text-balance font-heading tracking-tight"
  >
    {t.welcomeTitle}
  </h1>
  <p class="text-xs md:text-sm text-neutral-500 leading-relaxed max-w-lg mx-auto text-pretty">
    {description}
  </p>
</div>
