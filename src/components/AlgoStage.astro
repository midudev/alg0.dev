---
/**
 * Static algorithm stage (viz host + step description + mobile transport).
 * Behavior: `src/lib/algo-page.ts` via client bootstrap.
 */
import AlgorithmDescription from "@components/AlgorithmDescription.astro"
import type { Locale } from "@i18n/translations"
import { translations } from "@i18n/translations"
import { difficultyPresentation } from "@lib/difficulty"
import type { AlgorithmSummary, Step } from "@lib/types"

interface Props {
  locale: Locale
  algorithm: AlgorithmSummary
  /** Precomputed steps for first paint + bootstrap JSON. */
  steps: Step[]
  /** Full educational description for crawlable summary. */
  description?: string
  pageTitle?: string
  metaDescription?: string
}

const {
  locale,
  algorithm,
  steps,
  description = "",
  pageTitle,
  metaDescription,
} = Astro.props
const t = translations[locale]
const first = steps[0]
const difficulty = difficultyPresentation[algorithm.difficulty]
// Escape `<` so step strings never close the script tag early
const bootstrapJson = JSON.stringify({ locale, algorithm, steps }).replace(/</g, "\\u003c")
---

<div
  class="flex-1 flex flex-col overflow-hidden min-h-0 min-w-0"
  data-algo-page
  data-locale={locale}
>
  <script type="application/json" data-algo-bootstrap set:html={bootstrapJson} />

  <main
    id="main-content"
    class="flex-1 flex flex-col overflow-hidden min-h-0 min-w-0"
    aria-label={t.visualizationLabel}
  >
      <h1 class="sr-only" data-algo-sr-title>
        {algorithm.name} —{" "}
        {locale === "es" ? "Visualizador de algoritmos" : "Algorithm Visualizer"}
      </h1>

      <section
        class="shrink-0 flex flex-col h-[52%] min-h-[260px] max-h-[520px] overflow-hidden"
        aria-label={t.visualizationLabel}
        data-algorithm-demo
      >
        <div class="flex-1 flex flex-col px-3 py-3 md:px-5 md:py-4 min-h-0 overflow-hidden">
          <div data-step-viz class="flex-1 flex min-h-0 w-full" style="min-height: 200px"></div>
        </div>

        <div
          class="px-3 pb-3 md:px-5 md:pb-4 shrink-0"
          aria-live="polite"
          aria-atomic="true"
          data-step-description-host
        >
          {
            first?.description ? (
              <div
                data-step-description
                class="text-xs md:text-sm text-neutral-300 bg-white/5 rounded-lg px-3 py-2 md:px-5 md:py-3 border border-white/12"
              >
                <span class="text-amber-300/90 font-medium mr-2" data-step-label>
                  {t.step.replace("{n}", "1")}
                </span>
                <span data-step-text>{first.description}</span>
              </div>
            ) : null
          }
        </div>

      </section>

      {
        description ? (
          <section
            class="flex-1 min-h-[160px] flex flex-col border-t border-white/8"
            aria-label={locale === "es" ? "Explicación" : "Explanation"}
            data-algorithm-explanation
          >
            <header class="shrink-0 flex items-center gap-2.5 px-4 py-3 md:px-6 border-b border-white/8">
              <h2
                class="min-w-0 truncate text-sm font-semibold text-white font-heading"
                data-algorithm-explanation-title
              >
                {algorithm.name}
              </h2>
              <span
                class:list={[
                  "inline-flex shrink-0 items-center gap-1.5 px-2 py-0.5 text-[10px] font-semibold rounded-full border",
                  difficulty.background,
                  difficulty.color,
                ]}
                data-algorithm-difficulty={algorithm.difficulty}
              >
                <span
                  class:list={["w-1.5 h-1.5 rounded-full", difficulty.dot]}
                  data-algorithm-difficulty-dot
                />
                <span data-algorithm-difficulty-label>{difficulty.label[locale]}</span>
              </span>
              <button
                type="button"
                class="ml-auto shrink-0 inline-flex size-7 items-center justify-center rounded-md text-neutral-500 hover:text-white hover:bg-white/6 transition-colors"
                aria-expanded="true"
                aria-controls="algorithm-explanation-body"
                aria-label={locale === "es" ? "Minimizar explicación" : "Minimize explanation"}
                data-label-expand={locale === "es" ? "Mostrar explicación" : "Show explanation"}
                data-label-collapse={locale === "es" ? "Minimizar explicación" : "Minimize explanation"}
                data-algorithm-explanation-toggle
              >
                <svg
                  class="size-3.5"
                  viewBox="0 0 16 16"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" d="M3.5 8h9" data-explanation-icon-collapse />
                  <path
                    stroke-linecap="round"
                    d="M8 3.5v9M3.5 8h9"
                    data-explanation-icon-expand
                    hidden
                  />
                </svg>
              </button>
            </header>
            <div
              id="algorithm-explanation-body"
              class="flex-1 min-h-0 overflow-y-auto"
              tabindex="0"
              data-algorithm-explanation-scroll
            >
              <div
                class="max-w-3xl px-4 py-5 md:px-6 md:py-6"
                data-algorithm-explanation-content
              >
                <AlgorithmDescription
                  description={description}
                  difficulty={algorithm.difficulty}
                  locale={locale}
                  pageTitle={pageTitle}
                  metaDescription={metaDescription}
                  showHeader={false}
                  algorithm={algorithm}
                />
              </div>
            </div>
          </section>
        ) : null
      }
  </main>

  <!-- Mobile transport bar (shown by plain JS when md:max) -->
  <div
    data-mobile-transport
    class="shrink-0 items-center justify-between px-3 py-2 border-t border-white/8 bg-black z-10 gap-2 hidden"
  >
    <button
      type="button"
      data-mobile-sidebar-open
      class="w-8 h-8 flex items-center justify-center rounded-md hover:bg-white/6 text-neutral-400 hover:text-white transition-colors shrink-0"
      aria-label={t.openMenu}
    >
      <svg
        class="w-4 h-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
      </svg>
    </button>
    <div class="flex-1 flex items-center justify-center min-w-0">
      <div class="flex items-center gap-1" role="group" aria-label={t.controlsLabel}>
        <button
          type="button"
          data-mobile-step-back
          disabled
          class="p-1.5 rounded-md hover:bg-white/8 disabled:opacity-20 text-neutral-500 hover:text-white transition-all active:scale-95"
          aria-label={t.stepBackward}
        >
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M10.5 14.0607L9.96966 13.5303L5.14644 8.7071C4.75592 8.31658 4.75592 7.68341 5.14644 7.29289L9.96966 2.46966L10.5 1.93933L11.5607 2.99999L11.0303 3.53032L6.56065 7.99999L11.0303 12.4697L11.5607 13L10.5 14.0607Z"
              fill="currentColor"></path>
          </svg>
        </button>
        <button
          type="button"
          data-mobile-play
          class="w-8 h-8 rounded-full bg-white hover:bg-neutral-200 flex items-center justify-center transition-all active:scale-95"
          aria-label={t.playPause}
        >
          <svg
            data-mobile-icon-pause
            class="w-3.5 h-3.5 text-black"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            hidden
          >
            <rect x="6" y="5" width="4" height="14" rx="1"></rect>
            <rect x="14" y="5" width="4" height="14" rx="1"></rect>
          </svg>
          <svg
            data-mobile-icon-play
            class="w-3 h-3 text-black"
            viewBox="0 0 16 16"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M14.5528 7.77638C14.737 7.86851 14.737 8.13147 14.5528 8.2236L1.3618 14.8191C1.19558 14.9022 1 14.7813 1 14.5955L1 1.4045C1 1.21865 1.19558 1.09778 1.3618 1.18089L14.5528 7.77638Z"
              fill="currentColor"></path>
          </svg>
        </button>
        <button
          type="button"
          data-mobile-step-forward
          class="p-1.5 rounded-md hover:bg-white/8 disabled:opacity-20 text-neutral-500 hover:text-white transition-all active:scale-95"
          aria-label={t.stepForward}
        >
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M5.50001 1.93933L6.03034 2.46966L10.8536 7.29288C11.2441 7.68341 11.2441 8.31657 10.8536 8.7071L6.03034 13.5303L5.50001 14.0607L4.43935 13L4.96968 12.4697L9.43935 7.99999L4.96968 3.53032L4.43935 2.99999L5.50001 1.93933Z"
              fill="currentColor"></path>
          </svg>
        </button>
      </div>
      <span class="text-[11px] text-neutral-600 font-mono tabular-nums ml-2" data-mobile-step-label
        >1/{steps.length || "—"}</span
      >
    </div>
    <button
      type="button"
      data-mobile-code-open
      class="w-8 h-8 flex items-center justify-center rounded-md hover:bg-white/6 text-neutral-400 hover:text-white transition-colors shrink-0"
      aria-label={t.viewCode}
    >
      <svg
        class="w-4 h-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"
        ></path>
      </svg>
    </button>
  </div>
</div>

<style is:global>
  [data-algo-page][data-explanation-collapsed] [data-algorithm-demo] {
    flex: 1 1 0%;
    height: auto;
    max-height: none;
  }

  [data-algo-page][data-explanation-collapsed] [data-algorithm-explanation] {
    flex: 0 0 auto;
    min-height: 0;
  }

  [data-algo-page][data-explanation-collapsed] [data-algorithm-explanation-scroll] {
    display: none;
  }
</style>
