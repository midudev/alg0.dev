---
/**
 * Static playback toolbar (SSR). State sync + clicks live in `src/lib/controls.ts`.
 */
import type { Locale } from "@i18n/translations"
import { translations } from "@i18n/translations"

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = translations[locale]
---

<div class="controls flex items-center gap-5 min-w-0" role="toolbar" aria-label={t.controlsLabel} data-controls>
  <!-- Transport -->
  <div class="flex items-center shrink-0" role="group" aria-label={t.controlsLabel}>
    <button
      type="button"
      data-controls-back
      disabled
      class="controls-icon-btn"
      aria-label={t.stepBackward}
    >
      <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path
          fill-rule="evenodd"
          clip-rule="evenodd"
          d="M10.5 14.0607L9.96966 13.5303L5.14644 8.7071C4.75592 8.31658 4.75592 7.68341 5.14644 7.29289L9.96966 2.46966L10.5 1.93933L11.5607 2.99999L11.0303 3.53032L6.56065 7.99999L11.0303 12.4697L11.5607 13L10.5 14.0607Z"
        ></path>
      </svg>
    </button>

    <div class="relative flex items-center justify-center w-8 h-8">
      <div data-controls-ring class="contents"></div>
      <button
        type="button"
        data-controls-play
        disabled
        class="controls-play relative z-10"
        aria-label={t.playPause}
      >
        <svg
          data-controls-icon-pause
          class="w-3.5 h-3.5"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          hidden
        >
          <rect x="6" y="5" width="4" height="14" rx="1"></rect>
          <rect x="14" y="5" width="4" height="14" rx="1"></rect>
        </svg>
        <svg
          data-controls-icon-play
          class="w-3 h-3 ml-0.5"
          viewBox="0 0 16 16"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M14.5528 7.77638C14.737 7.86851 14.737 8.13147 14.5528 8.2236L1.3618 14.8191C1.19558 14.9022 1 14.7813 1 14.5955L1 1.4045C1 1.21865 1.19558 1.09778 1.3618 1.18089L14.5528 7.77638Z"
          ></path>
        </svg>
      </button>
    </div>

    <button
      type="button"
      data-controls-forward
      disabled
      class="controls-icon-btn"
      aria-label={t.stepForward}
    >
      <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path
          fill-rule="evenodd"
          clip-rule="evenodd"
          d="M5.50001 1.93933L6.03034 2.46966L10.8536 7.29288C11.2441 7.68341 11.2441 8.31657 10.8536 8.7071L6.03034 13.5303L5.50001 14.0607L4.43935 13L4.96968 12.4697L9.43935 7.99999L4.96968 3.53032L4.43935 2.99999L5.50001 1.93933Z"
        ></path>
      </svg>
    </button>
  </div>

  <!-- Progress scrubber + step count -->
  <div class="flex items-center gap-1.5 min-w-0">
    <div class="relative group/scrub flex items-center w-28 sm:w-36 lg:w-40 h-7 shrink-0">
      <div
        class="controls-track absolute inset-x-0 top-1/2 -translate-y-1/2 h-1 rounded-full overflow-hidden pointer-events-none"
      >
        <div
          data-controls-progress-fill
          class="controls-track-fill h-full rounded-full transition-[width] duration-200 ease-out"
          style="width: 0%"
        >
        </div>
      </div>
      <div
        data-controls-progress-thumb
        class="controls-thumb absolute top-1/2 -translate-y-1/2 size-2.5 rounded-full opacity-0 scale-75 group-hover/scrub:opacity-100 group-hover/scrub:scale-100 group-focus-within/scrub:opacity-100 group-focus-within/scrub:scale-100 transition-[opacity,transform,left] duration-150 ease-out pointer-events-none"
        style="left: calc(0% - 5px)"
        aria-hidden="true"
      >
      </div>
      <input
        type="range"
        data-controls-progress-input
        min="0"
        max="0"
        value="0"
        disabled
        aria-label={t.progressStep.replace("{current}", "0").replace("{total}", "0")}
        aria-valuemin="0"
        aria-valuemax="0"
        aria-valuenow="0"
        class="absolute inset-0 w-full h-full opacity-0 cursor-pointer disabled:cursor-default"
      />
    </div>

    <div
      class="tabular-nums font-mono text-[11px] select-none whitespace-nowrap"
      aria-hidden="true"
    >
      <span class="controls-step-current font-medium" data-controls-step-current>—</span>
      <span class="controls-step-sep">/</span>
      <span class="controls-step-total" data-controls-step-total>—</span>
    </div>
  </div>

  <!-- Speed -->
  <div class="hidden sm:flex items-center gap-1.5 shrink-0">
    <span
      class="controls-speed-label text-[11px] font-mono tabular-nums whitespace-nowrap"
      id="speed-label"
      data-controls-speed-label>0.75×</span
    >
    <div class="relative flex items-center w-16 h-7">
      <div
        class="controls-track absolute inset-x-0 top-1/2 -translate-y-1/2 h-1 rounded-full pointer-events-none"
      >
        <div
          data-controls-speed-fill
          class="controls-track-fill-muted h-full rounded-full transition-[width] duration-150 ease-out"
          style="width: 25%"
        >
        </div>
      </div>
      <div
        data-controls-speed-thumb
        class="controls-thumb absolute top-1/2 -translate-y-1/2 size-2.5 rounded-full transition-[left] duration-150 ease-out pointer-events-none"
        style="left: calc(25% - 5px)"
        aria-hidden="true"
      >
      </div>
      <input
        type="range"
        data-controls-speed-input
        data-speed-label-template={t.speedLevel}
        min="1"
        max="5"
        step="1"
        value="2"
        aria-labelledby="speed-label"
        aria-label={t.speedLevel.replace("{n}", "2")}
        aria-valuemin="1"
        aria-valuemax="5"
        aria-valuenow="2"
        aria-valuetext="0.75×"
        class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
      />
    </div>
  </div>
</div>
