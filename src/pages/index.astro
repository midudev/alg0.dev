---
import Layout from "@layouts/Layout.astro"
import AlgoViz from "@components/AlgoViz"
import { defaultLocale } from "@/i18n/translations"
import { getHomeStructuredData } from "@lib/seo"

const canonicalURL = new URL("/", Astro.site).href
---

<Layout
  locale={defaultLocale}
  canonicalURL={canonicalURL}
  structuredData={getHomeStructuredData(defaultLocale, canonicalURL)}
>
  <AlgoViz locale={defaultLocale} client:load />
</Layout>
