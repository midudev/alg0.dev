---
import Layout from "@layouts/Layout.astro"
import SiteHeader from "@components/SiteHeader.astro"
import AlgorithmDescription from "@components/AlgorithmDescription.astro"
import SiteSidebar from "@components/SiteSidebar.astro"
import CodePanelShell from "@components/CodePanelShell.astro"
import WelcomeChrome from "@components/WelcomeChrome.astro"
import AlgoViz from "@components/AlgoViz"
import { algorithmCatalog, getCatalogEntry } from "@lib/algorithms/catalog"
import { loadAlgorithm } from "@lib/algorithms/loaders"
import { defaultLocale } from "@i18n/translations"
import {
  getAlgorithmMetaTitle,
  getAlgorithmMetaDescription,
  loadAlgorithmDescription,
} from "@lib/algorithm-content"
import { getAlgorithmStructuredData } from "@lib/seo"
import type { GetStaticPaths } from "astro"

export const getStaticPaths: GetStaticPaths = async () => {
  return algorithmCatalog.map((algo) => ({
    params: { algorithm: algo.id },
  }))
}

const { algorithm } = Astro.params as { algorithm: string }
const algo = getCatalogEntry(algorithm)!

const full = await loadAlgorithm(algo.id)
const initialSteps = full.generateSteps(defaultLocale)
const algorithmDescription = await loadAlgorithmDescription(defaultLocale, algo.id)

const title = getAlgorithmMetaTitle(defaultLocale, algo.name, algorithmDescription)
const description = getAlgorithmMetaDescription(defaultLocale, algorithmDescription)
const canonicalURL = new URL(`/${algo.id}/`, Astro.site).href
---

<Layout
  locale={defaultLocale}
  title={title}
  description={description}
  canonicalURL={canonicalURL}
  structuredData={getAlgorithmStructuredData(
    defaultLocale,
    algo,
    canonicalURL,
    algorithmDescription,
  )}
>
  <div class="h-screen flex flex-col overflow-hidden">
    <SiteHeader locale={defaultLocale} algorithm={algo} />
    <div class="flex-1 flex overflow-hidden min-h-0 relative">
      <SiteSidebar locale={defaultLocale} selectedId={algo.id} />
      <AlgoViz
        locale={defaultLocale}
        initialAlgorithm={algo}
        initialCode={full.code}
        initialSteps={initialSteps}
        client:load
      >
        <AlgorithmDescription
          description={algorithmDescription}
          difficulty={algo.difficulty}
          locale={defaultLocale}
          pageTitle={title}
          metaDescription={description}
        />
        <WelcomeChrome locale={defaultLocale} slot="welcome-chrome" />
      </AlgoViz>
      <CodePanelShell locale={defaultLocale} initialCollapsed={false} />
    </div>
  </div>
</Layout>
